# --- Huly instance ---
HULY_URL=https://ppuboard.devoutsys.com
HULY_EMAIL=
HULY_PASSWORD=
# Workspace slug from the URL after login: .../workbench/<workspace>
HULY_WORKSPACE=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Summary API (Milestone 2) ---
# Snapshot store (Vercel KV / Upstash Redis REST): the cron writes the latest
# summary here, the serverless API reads it. Both reachable over HTTPS.
SNAPSHOT_STORE_URL=
SNAPSHOT_STORE_TOKEN=
# Bearer token consumers must present to the API: `Authorization: Bearer <token>`.
# Read by the serverless function (set it in the host's env, e.g. Vercel) — not
# needed by the cron, so it is not validated by the poller.
API_TOKEN=
